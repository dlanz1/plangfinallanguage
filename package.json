{
  "name": "3dtee",
  "version": "1.0.0",
  "description": "3DTee is a golf-themed statically typed language that compiles to JavaScript.",
  "main": "src/compiler.js",
  "bin": {
    "3dtee": "src/3DTee.js"
  },
  "scripts": {
  "test": "c8 node --test test/*.test.js",
