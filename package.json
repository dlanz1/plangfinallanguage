  "test:analyzer": "c8 node --test test/analyzer.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlanz1/3DTee.git"
  },
  "keywords": [
    "compiler",
    "language",
    "golf",
    "ohm-js",
    "javascript"
  ],
  "author": "3DTee Team",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/dlanz1/3DTee/issues"
  },
  "homepage": "https://github.com/dlanz1/3DTee#readme",
  "dependencies": {
    "graph-stringify": "^1.1.0",
    "ohm-js": "^17.5.0"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
